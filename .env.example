# ── Bootstrap-администратор (создаётся при первом старте) ─────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please

# ── Необязательное ────────────────────────────────────────────────────────────
# Каталог с сертификатами (внутри контейнера). Должен совпадать с монтированием.
# CERT_DIR=/etc/letsencrypt

# Публичный адрес сервера по умолчанию (IP/host), если не задан в настройках панели.
# PUBLIC_ADDRESS=203.0.113.10

# Персистентный ключ подписи сессий. Если не задан — генерируется и хранится в /data.
# SECRET_KEY=
